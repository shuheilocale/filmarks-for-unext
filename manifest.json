{
  "manifest_version": 3,
  "name": "U-NEXT Ratings",
  "version": "1.0.0",
  "description": "U-NEXTの作品詳細ページにレビューサイトのスコアを表示します",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://filmarks.com/*",
    "https://www.rottentomatoes.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://video.unext.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
